{
  "@context": {
    "@vocab": "https://schema.org/",
    "fax": "https://fax-network.org/schema#",
    "did": "https://w3id.org/did#",
    "ad": "https://agent-network-protocol.com/ad#"
  },
  "@type": "fax:AgentResourceProfile",
  "@id": "https://compute-provider.io/agents/alpha/resource-profile.json",
  "fax:agentDid": "did:wba:compute-provider.io:user:alpha",
  "name": "Compute Provider Alpha",
  "description": "High-performance GPU compute and WASM sandbox for agent workloads",

  "fax:offeredResources": [
    {
      "@type": "fax:TradableResource",
      "fax:resourceType": "fax:Compute",
      "fax:subtype": "gpu-hour",
      "fax:available": 8.0,
      "fax:unit": "gpu-hour",
      "fax:minTrade": 0.5,
      "fax:maxTrade": 8.0,
      "fax:qualityDescriptor": {
        "fax:gpuModel": "A100",
        "fax:memoryGB": 80,
        "fax:wasmSupported": true
      },
      "fax:availabilitySchedule": [
        {
          "fax:days": ["Mon", "Tue", "Wed", "Thu", "Fri"],
          "fax:startUtc": "02:00",
          "fax:endUtc": "08:00"
        },
        {
          "fax:days": ["Sat", "Sun"],
          "fax:startUtc": "00:00",
          "fax:endUtc": "23:59"
        }
      ]
    },
    {
      "@type": "fax:TradableResource",
      "fax:resourceType": "fax:Compute",
      "fax:subtype": "cpu-hour",
      "fax:available": 48.0,
      "fax:unit": "cpu-hour",
      "fax:minTrade": 1.0,
      "fax:maxTrade": 48.0
    }
  ],

  "fax:acceptedResources": [
    {"fax:resourceType": "fax:LlmTokens", "fax:minPerTrade": 10000},
    {"fax:resourceType": "fax:KnowledgeAccess", "fax:domains": ["financial-markets", "technology"]},
    {"fax:resourceType": "fax:ResearchReport", "fax:domains": ["technology", "geopolitics"]},
    {"fax:resourceType": "fax:Attestation"}
  ],

  "fax:exchangeRates": [
    {
      "fax:give": {"fax:type": "fax:Compute", "fax:amount": 1, "fax:unit": "gpu-hour"},
      "fax:receive": {"fax:type": "fax:LlmTokens", "fax:amount": 50000, "fax:unit": "tokens"},
      "fax:rateType": "indicative",
      "fax:validUntil": "2026-04-01T00:00:00Z"
    },
    {
      "fax:give": {"fax:type": "fax:Compute", "fax:amount": 4, "fax:unit": "gpu-hour"},
      "fax:receive": {"fax:type": "fax:ResearchReport", "fax:amount": 1, "fax:unit": "report"},
      "fax:rateType": "negotiable"
    }
  ],

  "fax:tradingPolicy": {
    "fax:minSecurityLevel": 1,
    "fax:requiresBlockchainAnchor": true,
    "fax:acceptsCredit": false,
    "fax:maxConcurrentTrades": 3,
    "fax:disputeResolution": "did:wba:arbitration.fax-network.org:agent:resolver"
  },

  "ad:interfaces": [
    {
      "@type": "ad:StructuredInterface",
      "ad:protocol": "FAX/1.0",
      "ad:version": "0.1.0",
      "ad:url": "https://compute-provider.io/agents/alpha/fax-api.json",
      "ad:description": "FAX resource trading protocol endpoint"
    }
  ]
}
